name: Build and Release Android App

on:
  push:
    branches:
      - main

jobs:
  build-release:

    runs-on: ubuntu-latest

    steps:
    # 1️⃣ Checkout code
    - name: Checkout repository
      uses: actions/checkout@v4

    # 2️⃣ Setup Node.js
    - name: Setup Node
      uses: actions/setup-node@v4
      with:
        node-version: 18

    # 3️⃣ Install Cordova
    - name: Install Cordova
      run: npm install -g cordova

    # 4️⃣ Install dependencies
    - name: Install project dependencies
      run: npm install

    # 5️⃣ Add Android platform
    - name: Add Android platform
      run: cordova platform add android

    # 6️⃣ Decode the Keystore
    - name: Decode Keystore
      run: |
        echo "${{ secrets.KEYSTORE_BASE64 }}" | base64 --decode > adullam-release-key.jks

    # 7️⃣ Build signed APK + AAB
    - name: Build APK and AAB
      run: |
        cordova build android --release \
          -- --keystore=adullam-release-key.jks \
          --storePassword="${{ secrets.KEYSTORE_PASSWORD }}" \
          --alias="${{ secrets.KEY_ALIAS }}" \
          --password="${{ secrets.KEY_PASSWORD }}" \
          --packageType=bundle
        cordova build android --release \
          -- --keystore=adullam-release-key.jks \
          --storePassword="${{ secrets.KEYSTORE_PASSWORD }}" \
          --alias="${{ secrets.KEY_ALIAS }}" \
          --password="${{ secrets.KEY_PASSWORD }}" \
          --packageType=apk

    # 8️⃣ Upload APK as artifact
    - name: Upload APK
      uses: actions/upload-artifact@v4
      with:
        name: adullam-apk
        path: platforms/android/app/build/outputs/apk/release/*.apk

    # 9️⃣ Upload AAB as artifact
    - name: Upload AAB
      uses: actions/upload-artifact@v4
      with:
        name: adullam-aab
        path: platforms/android/app/build/outputs/bundle/release/*.aab

    # 🔟 Create GitHub Release and attach APK + AAB
    - name: Create GitHub Release
      uses: softprops/action-gh-release@v1
      with:
        tag_name: "v1.0.${{ github.run_number }}"
        name: "Adullam App Release v1.0.${{ github.run_number }}"
      env:
        GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

    - name: Upload APK to Release
      uses: actions/upload-release-asset@v1
      with:
        upload_url: ${{ steps.create_release.outputs.upload_url }}
        asset_path: platforms/android/app/build/outputs/apk/release/app-release.apk
        asset_name: adullam.apk
        asset_content_type: application/vnd.android.package-archive

    - name: Upload AAB to Release
      uses: actions/upload-release-asset@v1
      with:
        upload_url: ${{ steps.create_release.outputs.upload_url }}
        asset_path: platforms/android/app/build/outputs/bundle/release/app-release.aab
        asset_name: adullam.aab
        asset_content_type: application/octet-stream
